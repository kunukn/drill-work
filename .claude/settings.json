{
  "permissions": {
    "ask": ["Bash(git *)"],
    "allow": [
      "Bash(git log:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker version)",
      "Bash(docker info)",
      "Bash(docker stats:*)",
      "Bash(docker top:*)",
      "Bash(docker port:*)",
      "Bash(docker history:*)",
      "Bash(docker diff:*)",
      "Bash(docker events:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down)",
      "Bash(npm view *)",
      "Bash(grep -v \"^$\")",
      "Bash(pnpm --version)",
      "Bash(pnpm install)",
      "Bash(pnpm dev *)",
      "Bash(pnpm build)",
      "Bash(pnpm preview)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm format:check)",
      "Bash(pnpm check)",
      "Bash(curl -s -o /dev/null -w \"home: %{http_code}\\\\n\" http://localhost:*)",
      "Bash(curl -s http://localhost:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ]
  }
}
